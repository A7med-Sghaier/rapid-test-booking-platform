doctype html
html(lang='en')
    head
        title Request Resgistration Data!
        link(rel='stylesheet' href='https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css')
        style.
            qr{
                background-image: url(#{data.qr});
                background-position: center;
                background-size: contain;
                background-repeat: no-repeat;
                height: 10rem;
            }
    body
        div.w-100.d-flex.flex-column.align-items-center.justify-content-center
            div.p-3
                div.text-center.fw-bold Mit dieser URL oder dem angehängten QR-CODE können Sie erneut einen Termin buchen
                div.mt-1.w-100.text-center
                    a(href=data.url) URL für neue Terminbuchung.
