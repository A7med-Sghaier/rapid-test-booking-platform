doctype html
html(lang='en')
    head
        title Request Resgistration Data!
        link(rel='stylesheet' href='https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css')
        style.
            qr{
                background-image: url(#{data.qr});
                background-position: center;
                background-size: contain;
                background-repeat: no-repeat;
                height: 10rem;
            }
    body
        div.w-100
            div.ps-3.mt-2.fw-bold Buchungsbestätigung
                div.mt-4.fw-normal Sehr geehrter Herr/Frau #{data.person.firstName} #{data.person.secondName},
                div.mt-2.fw-normal  Sie erhalten hiermit Ihren persönlichen Check-In QR-Code für den Test angehängt.

            div.ps-3.mt-4.fw-bold Übersicht Anmeldung:
                ul.p-3
                    li.p1.fw-normal #{data.testType.label}
                        data.testType.price
                        if data.testType.price
                            span : #{data.testType.price}€
                        else
                            span
                    li.p1.fw-normal #{data.appointment}
                    li.p1.fw-normal #{data.persons}


            div.ps-3.mt-4.fw-bold Adresse:
                div.ps-1.fw-bold #{data.center.name}
                div.ps-1.fw-normal #{data.center.address}

            div.d-flex.py-3
                div(style='background: #002940; color: #fff').me-2
                    a(href=data.cancelUrl).btn.text-white Termin stornieren

                div(style='background: #002940; color: #fff').ms-2
                    a(href=data.rebookUrl).btn.text-white Neuen Termin buchen
