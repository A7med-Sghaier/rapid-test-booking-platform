# Application
APP_DOMAIN=localhost
NODE_PORT=3500
APP_NAME=Rapid Test Booking Platform
NODE_ENV=development

# MongoDB
DB_HOST=localhost
DB_PORT=27017
DB_NAME=rapid-test-booking
# Optional base64-encoded credentials if your MongoDB instance requires auth.
DB_USER=
DB_PWD=

# Mail
MAIL_HOST=smtp.example.com
MAIL_USER=no-reply@example.com
MAIL_PWD=replace-with-local-mail-password

# Auth and encryption
JWT_SECRET=replace-with-long-random-secret
CRYPTO_KEY=replace-with-long-random-key

# Collections
COLLECTION_LOGIN=logins
COLLECTION_APPOINTMENTS=appointments
COLLECTION_SETTINGS=settings

# Corona-Warn-App integration placeholders
CWA_HOST=https://example.com
CWA_WRU_KEY=replace-with-local-wru-key
CWA_CERT=replace-with-local-certificate
CWA_PASS=replace-with-local-certificate-password
