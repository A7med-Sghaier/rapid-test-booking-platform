# Application
APP_DOMAIN=localhost
NODE_PORT=3500
APP_NAME=Rapid Test Booking Platform
NODE_ENV=development

# MongoDB
DB_HOST=localhost
DB_PORT=27017
DB_NAME=rapid-test-booking
# Optional base64-encoded values if your MongoDB instance requires auth.
DB_USER=
DB_PWD=

# Mail
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_SECURE=false
MAIL_USER=local-mailpit-user
MAIL_PWD=local-mailpit-token

# Auth and encryption
JWT_SECRET=local-development-jwt-token
CRYPTO_KEY=local-development-crypto-token

# Collections
COLLECTION_LOGIN=logins
COLLECTION_APPOINTMENTS=appointments
COLLECTION_SETTINGS=settings

# Corona-Warn-App integration placeholders
CWA_HOST=https://example.com
CWA_WRU_KEY=local-wru-token
CWA_CERT=local-certificate-placeholder
CWA_PASS=local-certificate-token
